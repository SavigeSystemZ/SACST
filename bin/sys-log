#!/usr/bin/env bash
set -Eeuo pipefail

source "$(cd "$(dirname "$0")" && pwd)/sys-common.sh"

PROJECT_ROOT=""
KIND="action"
MESSAGE=""
ACTION_CLASS=""
STATUS="ok"
SESSION_ID=""
ACTOR="${USER:-unknown}"
MODE=""
TARGETS=""
COMMAND_SUMMARY=""
ROLLBACK_REFS=""

while [ $# -gt 0 ]; do
  case "$1" in
    --project)
      PROJECT_ROOT="$(resolve_project_arg "$2")"
      shift 2
      ;;
    --kind)
      KIND="$2"
      shift 2
      ;;
    --message)
      MESSAGE="$2"
      shift 2
      ;;
    --action-class)
      ACTION_CLASS="$2"
      shift 2
      ;;
    --status)
      STATUS="$2"
      shift 2
      ;;
    --session-id)
      SESSION_ID="$2"
      shift 2
      ;;
    --actor)
      ACTOR="$2"
      shift 2
      ;;
    --mode)
      MODE="$2"
      shift 2
      ;;
    --targets)
      TARGETS="$2"
      shift 2
      ;;
    --command)
      COMMAND_SUMMARY="$2"
      shift 2
      ;;
    --rollback-refs)
      ROLLBACK_REFS="$2"
      shift 2
      ;;
    *)
      die "unexpected argument: $1"
      ;;
  esac
done

[ -n "$PROJECT_ROOT" ] || die "--project is required"
[ -f "$PROJECT_ROOT/control/PROJECT_PROFILE.yaml" ] || die "not a SACST project repo: $PROJECT_ROOT"

case "$KIND" in
  action) LOG_FILE="$PROJECT_ROOT/logs/actions.jsonl" ;;
  critical) LOG_FILE="$PROJECT_ROOT/logs/critical-actions.jsonl" ;;
  feedback) LOG_FILE="$PROJECT_ROOT/logs/feedback.jsonl" ;;
  session) LOG_FILE="$PROJECT_ROOT/logs/sessions.jsonl" ;;
  *) die "invalid log kind: $KIND" ;;
esac

[ -n "$MODE" ] || MODE="$(current_mode "$PROJECT_ROOT")"
[ -n "$SESSION_ID" ] || SESSION_ID="$(timestamp_compact)"
mkdir -p "$(dirname "$LOG_FILE")"

python3 - "$LOG_FILE" "$KIND" "$MESSAGE" "$ACTION_CLASS" "$STATUS" "$SESSION_ID" "$ACTOR" "$MODE" "$TARGETS" "$COMMAND_SUMMARY" "$ROLLBACK_REFS" <<'PY'
import json
import sys
from datetime import datetime, timezone

log_file, kind, message, action_class, status, session_id, actor, mode, targets, command_summary, rollback_refs = sys.argv[1:]
ts = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
entry = {
    "schema_version": 1,
    "ts": ts,
    "session_id": session_id,
    "actor": actor,
    "mode": mode,
    "message": message,
}
if kind in ("action", "critical"):
    entry["action_class"] = action_class or "unspecified"
    entry["status"] = status
    entry["targets"] = [item for item in targets.split(",") if item]
    entry["command_summary"] = command_summary
    entry["rollback_refs"] = [item for item in rollback_refs.split(",") if item]
elif kind == "feedback":
    entry["user_signal"] = status or "neutral"
elif kind == "session":
    entry["tool_name"] = actor
    entry["started_at"] = ts
with open(log_file, "a", encoding="utf-8") as fh:
    fh.write(json.dumps(entry, sort_keys=True) + "\n")
PY

echo "Logged $KIND event to $LOG_FILE"
