#!/usr/bin/env bash
set -Eeuo pipefail

ROOT="${SYS_AGENT_ROOT:-/home/whyte/.MyAdminZ/_SYS_AGENT_CORE_TEMPLATE}"

show_help() {
    echo "Usage: sys-scaffold <mode> [args]"
    echo "Modes:"
    echo "  new <name>    Initialize a new system instance"
    echo "  update <name> Update framework logic in an existing instance"
    echo "  backup <name> Create a portable backup of an instance"
}

mode="${1:-}"
name="${2:-}"

if [ -z "$mode" ] || [ -z "$name" ]; then
    show_help
    exit 1
fi

case "$mode" in
    new)
        echo "Initializing new instance: $name"
        "$ROOT/framework/bin/sys-init" "$name"
        # Additional scaffolding logic could go here
        ;;
    update)
        echo "Updating framework in existing instance: $name"
        INST_DIR="$ROOT/instances/$name"
        if [ ! -d "$INST_DIR" ]; then
            echo "Error: Instance $name does not exist."
            exit 1
        fi
        # Re-run init to ensure directories and basic files exist
        "$ROOT/framework/bin/sys-init" "$name"
        # Force update of tool adapters from templates (if templates existed)
        # For now, we just ensure sys-doctor passes
        "$ROOT/framework/bin/sys-doctor" "$name"
        ;;
    backup)
        echo "Backing up instance: $name"
        tar -czf "$ROOT/instances/${name}_backup_$(date +%Y%m%d).tar.gz" -C "$ROOT/instances" "$name"
        echo "Backup created in $ROOT/instances/"
        ;;
    *)
        show_help
        exit 1
        ;;
esac
