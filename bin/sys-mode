#!/usr/bin/env bash
set -Eeuo pipefail

source "$(cd "$(dirname "$0")" && pwd)/sys-common.sh"

usage() {
  cat <<'EOF'
Usage: sys-mode <project-path|instance-name> [advisor|operator|yolo]
EOF
}

[ $# -ge 1 ] || { usage; exit 1; }

PROJECT_ROOT="$(resolve_project_arg "$1")"
[ -f "$PROJECT_ROOT/control/MODE_POLICY.yaml" ] || die "not a SACST project repo: $PROJECT_ROOT"

if [ $# -eq 1 ]; then
  echo "$(current_mode "$PROJECT_ROOT")"
  exit 0
fi

NEW_MODE="$2"
case "$NEW_MODE" in
  advisor|operator|yolo) ;;
  *) die "invalid mode: $NEW_MODE" ;;
esac

sed -i "s/^mode: .*/mode: $NEW_MODE/" "$PROJECT_ROOT/runtime/MODE_STATE.yaml"
if [ -f "$PROJECT_ROOT/runtime/RUNTIME_STATE.yaml" ]; then
  sed -i "s/^mode: .*/mode: $NEW_MODE/" "$PROJECT_ROOT/runtime/RUNTIME_STATE.yaml"
fi

echo "Mode set to $NEW_MODE for $PROJECT_ROOT"
