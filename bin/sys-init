#!/usr/bin/env bash
set -Eeuo pipefail

source "$(cd "$(dirname "$0")" && pwd)/sys-common.sh"

usage() {
  cat <<'EOF'
Usage: sys-init <instance-name> [--path <project-path>] [--platform <platform>] [--adopt-existing] [--no-refresh] [--no-git-bootstrap] [--create-remote] [--dry-run]
EOF
}

[ $# -ge 1 ] || { usage; exit 1; }

INSTANCE_NAME=""
PROJECT_ROOT=""
PRIMARY_PLATFORM="linux-desktop"
ADOPT_EXISTING="false"
NO_REFRESH="false"
GIT_BOOTSTRAP="true"
CREATE_REMOTE="false"
DRY_RUN="false"

while [ $# -gt 0 ]; do
  case "$1" in
    --path)
      PROJECT_ROOT="$2"
      shift 2
      ;;
    --platform)
      PRIMARY_PLATFORM="$2"
      shift 2
      ;;
    --adopt-existing)
      ADOPT_EXISTING="true"
      shift
      ;;
    --no-refresh)
      NO_REFRESH="true"
      shift
      ;;
    --no-git-bootstrap)
      GIT_BOOTSTRAP="false"
      shift
      ;;
    --create-remote)
      CREATE_REMOTE="true"
      shift
      ;;
    --dry-run)
      DRY_RUN="true"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      if [ -z "$INSTANCE_NAME" ]; then
        INSTANCE_NAME="$1"
        shift
      else
        die "unexpected argument: $1"
      fi
      ;;
  esac
done

[ -n "$INSTANCE_NAME" ] || die "instance name is required"

if [ -z "$PROJECT_ROOT" ]; then
  PROJECT_ROOT="$(resolve_project_arg "$INSTANCE_NAME")"
else
  PROJECT_ROOT="$(realpath_safe "$PROJECT_ROOT")"
fi

ensure_project_outside_template "$PROJECT_ROOT"

ADOPTION_MODE="false"
if [ -d "$PROJECT_ROOT" ] && [ -n "$(find "$PROJECT_ROOT" -mindepth 1 -maxdepth 1 2>/dev/null | head -n 1)" ] && [ ! -f "$PROJECT_ROOT/control/PROJECT_PROFILE.yaml" ]; then
  if [ "$ADOPT_EXISTING" != "true" ]; then
    die "project path exists but does not look like a SACST project repo: $PROJECT_ROOT (use --adopt-existing to migrate it in place)"
  fi
  ADOPTION_MODE="true"
fi

if [ "$DRY_RUN" = "true" ]; then
  echo "DRY RUN: instance=$INSTANCE_NAME"
  echo "DRY RUN: project_root=$PROJECT_ROOT"
  echo "DRY RUN: platform=$PRIMARY_PLATFORM"
  echo "DRY RUN: adopt_existing=$ADOPTION_MODE"
  echo "DRY RUN: create_remote=$CREATE_REMOTE"
  if [ "$ADOPTION_MODE" = "true" ]; then
    echo "DRY RUN: template-managed paths that would be backed up/replaced:"
    template_managed_paths
    echo "DRY RUN: legacy control surfaces that would be archived:"
    printf '%s\n' control/AGENTS.md control/GEMINI.md control/CLAUDE.md control/.github control/.cursor
  fi
  exit 0
fi

CREATED_AT_UTC="$(timestamp_utc)"
VERSION="$(template_version)"
IMPORT_ROOT=""

ensure_project_dirs "$PROJECT_ROOT"
copy_initial_templates "$PROJECT_ROOT" "$INSTANCE_NAME" "$PRIMARY_PLATFORM" "$CREATED_AT_UTC" "$VERSION"

if [ "$ADOPTION_MODE" = "true" ]; then
  IMPORT_ROOT="$PROJECT_ROOT/state/imports/$(timestamp_compact)"
  mkdir -p "$IMPORT_ROOT"
  while IFS= read -r managed; do
    [ -n "$managed" ] || continue
    backup_path_if_exists "$PROJECT_ROOT" "$IMPORT_ROOT" "$managed"
  done < <(template_managed_paths)
  for legacy in control/AGENTS.md control/GEMINI.md control/CLAUDE.md control/.github control/.cursor; do
    move_path_to_import_if_exists "$PROJECT_ROOT" "$IMPORT_ROOT/legacy-control" "$legacy"
  done
fi

render_project_template_subset "$PROJECT_ROOT" "$INSTANCE_NAME" "$PRIMARY_PLATFORM" "$CREATED_AT_UTC" "$VERSION" "$ADOPTION_MODE"
ensure_project_owned_defaults "$PROJECT_ROOT"
upgrade_runtime_contracts "$PROJECT_ROOT"

touch "$PROJECT_ROOT/logs/actions.jsonl"
touch "$PROJECT_ROOT/logs/critical-actions.jsonl"
touch "$PROJECT_ROOT/logs/feedback.jsonl"
touch "$PROJECT_ROOT/logs/sessions.jsonl"

mkdir -p "$PROJECT_ROOT/reports/history" "$PROJECT_ROOT/reports/latest"
[ -f "$PROJECT_ROOT/runtime/CURRENT_MISSION.md" ] || printf "# Current mission\n" > "$PROJECT_ROOT/runtime/CURRENT_MISSION.md"
[ -f "$PROJECT_ROOT/runtime/CURRENT_PLAN.md" ] || printf "# Current plan\n" > "$PROJECT_ROOT/runtime/CURRENT_PLAN.md"
[ -f "$PROJECT_ROOT/runtime/NEXT_ACTIONS.md" ] || printf "# Next actions\n" > "$PROJECT_ROOT/runtime/NEXT_ACTIONS.md"

"$SYS_AGENT_ROOT/bin/sys-generate-adapters" "$PROJECT_ROOT"

if [ "$ADOPTION_MODE" = "true" ]; then
  "$SYS_AGENT_ROOT/bin/sys-reconcile-project" "$PROJECT_ROOT" >/dev/null
  write_adoption_report "$PROJECT_ROOT" "$IMPORT_ROOT"
  migrate_legacy_logs_if_needed "$PROJECT_ROOT" "$IMPORT_ROOT"
fi

if [ "$GIT_BOOTSTRAP" = "true" ]; then
  GIT_ARGS=( "$PROJECT_ROOT" )
  [ "$CREATE_REMOTE" = "true" ] && GIT_ARGS+=( --create-remote )
  "$SYS_AGENT_ROOT/bin/sys-git-bootstrap" "${GIT_ARGS[@]}" >/dev/null
fi

if [ "$NO_REFRESH" = "false" ]; then
  "$SYS_AGENT_ROOT/bin/sys-refresh" "$PROJECT_ROOT"
fi

echo "Initialized SACST project repo: $PROJECT_ROOT"
