#!/usr/bin/env bash
set -Eeuo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"

if [ $# -eq 0 ]; then
  exec "$ROOT/bin/sys-validate" --template
fi

case "$1" in
  --template)
    exec "$ROOT/bin/sys-validate" --template
    ;;
  --fix-template)
    exec "$ROOT/bin/sys-fix" --template
    ;;
  --meta)
    exec "$ROOT/bin/sys-meta-check"
    ;;
  *)
    exec "$ROOT/bin/sys-validate" --project "$1"
    ;;
esac
