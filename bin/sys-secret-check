#!/usr/bin/env bash
set -Eeuo pipefail

source "$(cd "$(dirname "$0")" && pwd)/sys-common.sh"

usage() {
  cat <<'EOF'
Usage:
  sys-secret-check <project-path|instance-name>
  sys-secret-check <project-path|instance-name> --ref <secret-ref>

Validates that project credential references point to available lookup mechanisms.
It never prints or stores secret values.
EOF
}

[ $# -ge 1 ] || { usage; exit 1; }

PROJECT_ROOT="$(resolve_project_arg "$1")"
shift
REF_OVERRIDE=""

while [ $# -gt 0 ]; do
  case "$1" in
    --ref)
      REF_OVERRIDE="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unexpected argument: $1"
      ;;
  esac
done

[ -f "$PROJECT_ROOT/control/CREDENTIAL_REFERENCES.yaml" ] || die "missing credential references file: $PROJECT_ROOT/control/CREDENTIAL_REFERENCES.yaml"

python3 - "$PROJECT_ROOT/control/CREDENTIAL_REFERENCES.yaml" "$REF_OVERRIDE" <<'PY'
import os
import shutil
import subprocess
import sys

import yaml

cred_file, ref_override = sys.argv[1:]

if ref_override:
    refs = [{"name": "override", "ref": ref_override, "purpose": "explicit check"}]
else:
    with open(cred_file, "r", encoding="utf-8") as fh:
        data = yaml.safe_load(fh) or {}
    refs = data.get("references", [])

failures = []

def ok(message):
    print(f"PASS: {message}")

def fail(message):
    print(f"FAIL: {message}")
    failures.append(message)

def command_exists(name):
    return shutil.which(name) is not None

for item in refs:
    name = str(item.get("name") or "unnamed")
    ref = str(item.get("ref") or "").strip()
    if not ref:
        fail(f"{name}: empty credential ref")
        continue

    if ref.startswith("env:"):
        variable = ref.split(":", 1)[1]
        if variable and os.environ.get(variable):
            ok(f"{name}: env reference exists ({variable})")
        else:
            fail(f"{name}: env reference is missing or empty ({variable})")
    elif ref.startswith("ssh-agent:"):
        if not command_exists("ssh-add"):
            fail(f"{name}: ssh-add is not available")
            continue
        proc = subprocess.run(["ssh-add", "-l"], stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
        if proc.returncode == 0 and proc.stdout.strip():
            ok(f"{name}: ssh-agent has at least one identity")
        else:
            fail(f"{name}: ssh-agent has no loaded identities")
    elif ref.startswith("pass:"):
        path = ref.split(":", 1)[1]
        if not command_exists("pass"):
            fail(f"{name}: pass is not installed")
        elif not path:
            fail(f"{name}: pass path is empty")
        else:
            proc = subprocess.run(["pass", "show", path], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            if proc.returncode == 0:
                ok(f"{name}: pass entry exists ({path})")
            else:
                fail(f"{name}: pass entry is unavailable ({path})")
    elif ref.startswith("1password:"):
        target = ref.split(":", 1)[1]
        if not command_exists("op"):
            fail(f"{name}: 1Password CLI 'op' is not installed")
        elif not target:
            fail(f"{name}: 1Password target is empty")
        else:
            ok(f"{name}: 1Password reference syntax recognized ({target})")
    elif ref.startswith("secret-tool:"):
        target = ref.split(":", 1)[1]
        if not command_exists("secret-tool"):
            fail(f"{name}: secret-tool is not installed")
        elif not target:
            fail(f"{name}: secret-tool target is empty")
        else:
            ok(f"{name}: secret-tool reference syntax recognized ({target})")
    elif ref.startswith("hardware-token:"):
        target = ref.split(":", 1)[1]
        if target:
            ok(f"{name}: hardware-token reference syntax recognized ({target})")
        else:
            fail(f"{name}: hardware-token target is empty")
    else:
        fail(f"{name}: unsupported credential reference scheme ({ref})")

if failures:
    raise SystemExit(1)
PY
