#!/usr/bin/env bash
set -Eeuo pipefail

source "$(cd "$(dirname "$0")" && pwd)/sys-common.sh"

usage() {
  cat <<'EOF'
Usage: sys-scope-check <project-path|instance-name> --activity <activity>

Checks whether a security or assessment activity is allowed by the project-local
control/SECURITY_SCOPE.yaml file. SACST project scopes default to full-spectrum
red/blue/purple security operations gated by the operator's current authorized
tasking.
EOF
}

[ $# -ge 3 ] || { usage; exit 1; }

PROJECT_ROOT="$(resolve_project_arg "$1")"
shift
ACTIVITY=""

while [ $# -gt 0 ]; do
  case "$1" in
    --activity)
      ACTIVITY="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unexpected argument: $1"
      ;;
  esac
done

[ -n "$ACTIVITY" ] || die "--activity is required"
[ -f "$PROJECT_ROOT/control/SECURITY_SCOPE.yaml" ] || die "missing project security scope: $PROJECT_ROOT/control/SECURITY_SCOPE.yaml"

python3 - "$PROJECT_ROOT/control/SECURITY_SCOPE.yaml" "$ACTIVITY" <<'PY'
import sys
import yaml

scope_file, activity = sys.argv[1:]

with open(scope_file, "r", encoding="utf-8") as fh:
    scope = yaml.safe_load(fh) or {}

authorized = bool(scope.get("authorized_security_testing", False))
authorization_model = str(scope.get("authorization_model") or "explicit-roe").strip()
operator_authorization_required = bool(scope.get("operator_authorization_required", True))
allowed = {str(item) for item in scope.get("allowed_activities", [])}
prohibited = {str(item) for item in scope.get("prohibited_activities", [])}
roe_ref = str(scope.get("rules_of_engagement_ref") or "").strip()
approval_ref = str(scope.get("approval_ref") or "").strip()

defensive_default = {
    "inventory",
    "exposure_review",
    "configuration_review",
    "patch_verification",
    "hardening",
    "security_review",
    "read_only_assessment",
}

authorization_required = {
    "exploit_validation",
    "password_auditing",
    "credential_audit",
    "wireless_testing",
    "web_application_testing",
    "lateral_movement_simulation",
    "controlled_load_testing",
    "load_testing",
    "social_engineering",
    "red_team_assessment",
    "purple_team_validation",
}

if activity in prohibited:
    raise SystemExit(f"security activity is prohibited by project scope: {activity}")

if activity not in allowed:
    raise SystemExit(f"security activity is not allowed by project scope: {activity}")

if activity in defensive_default:
    print(f"Scope check passed for defensive activity: {activity}")
    raise SystemExit(0)

if not authorized:
    raise SystemExit(
        f"security activity requires authorized_security_testing=true in control/SECURITY_SCOPE.yaml: {activity}"
    )

if activity in authorization_required and (not roe_ref or not approval_ref):
    raise SystemExit(
        f"security activity requires rules_of_engagement_ref and approval_ref, or operator-current-task placeholders, before execution: {activity}"
    )

if operator_authorization_required:
    print(
        f"Scope check passed for operator-gated security activity: {activity} "
        f"({authorization_model})"
    )
else:
    print(f"Scope check passed for authorized security activity: {activity}")
PY
